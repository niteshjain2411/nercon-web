function Win_scroll(theURL,wide,high,name) {
	var window_left = (screen.width-640)/2;
	var window_top = (screen.height-480)/2;
	if (!name) name="Newpopup";
	var win = window.open(theURL,name,'width='+wide+',height='+high+',scrollbars=yes,resizable=no,top=' + window_top + ',left=' + window_left + '');
	win.focus();
}

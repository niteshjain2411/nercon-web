function IDInputCheck(str){
	var ValidID = /^[A-Za-z][A-Za-z0-9_]{3,20}$/;
	if (!ValidID.test(str)) {
		alert("IDë¥¼ ë‹¤ì‹œ í™•ì¸í•´ì£¼ì„¸ìš”!\n\nID ì²«ê¸€ìžëŠ” ì˜ë¬¸ìžì´ì–´ì•¼ í•˜ë©°, ê³µë°±ì—†ì´ 4~20ìžì˜ ì˜ë¬¸, ìˆ«ìž, _ë¡œ êµ¬ì„±í•´ì•¼ í•©ë‹ˆë‹¤.");
		return false;
	}
	return true;
}

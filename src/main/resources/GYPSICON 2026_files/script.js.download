}

// íŒŒì¼ëª… ì²´í¬
function chkFileName(obj) {
	var str = obj.value;
	var file_name_ar = str.split("\\");
	var file_name = file_name_ar[file_name_ar.length-1];
	var file_name_len = str.length;

	if (file_name_len>255) {
		alert("File name is too long."); //íŒŒì¼ëª…ì´ ë„ˆë¬´ ê¹ë‹ˆë‹¤.
		obj.focus();
		return false;
	}
	var filter = /Â®|\'|\"|\<|\>|\||\?|\/|:|\+|\&|\*/g; //íŠ¹ìˆ˜ë¬¸ìžíŒ¨í„´
	if (filter.test(file_name)) {
		alert("Filename contains special characters are not allowed."); //íŒŒì¼ëª…ì— í—ˆìš©ë˜ì§€ ì•ŠëŠ” íŠ¹ìˆ˜ë¬¸ìžê°€ ë“¤ì–´ìžˆìŠµë‹ˆë‹¤.
		obj.focus();
		return false;
	} else {
		return true;
	}
}

// ì „í™”ë²ˆí˜¸(í•¸ë“œí°,íŒ©ìŠ¤í¬í•¨) ì²´í¬ (ì „í™”ë²ˆí˜¸ê°€ ì´ìƒí•˜ë©´ true ì•ˆì´ìƒí•˜ë©´ false)
function chkTel_msg(a, b, c, target) {
	var tel = new Array("02","031","032","033","041","042","043","051","052","053","054","055","061","062","063","064","010","011","016","017","018","019");
	var pcs = new Array("010","011","016","017","018","019");

	var isNum = /^[\d]+$/;
	var a_len = a.value.length;
	var b_len = b.value.length;
	var c_len = c.value.length;
	var msg1 = target + "ë²ˆí˜¸ë¥¼ ìž…ë ¥í•˜ì„¸ìš”.";
	var msg2 = target + "ë²ˆí˜¸ ìžë¦¿ìˆ˜ë¥¼ í™•ì¸í•˜ì„¸ìš”.";
	if (target == "ì—°ë½ì²˜") {
		var msg1 = target + "ë¥¼ ìž…ë ¥í•˜ì„¸ìš”.";
		var msg2 = target + " ìžë¦¿ìˆ˜ë¥¼ í™•ì¸í•˜ì„¸ìš”.";
	}

	if (chkBlank_msg(a,msg1)) return true;
	if (a.value.search(isNum)) { alert("ìˆ«ìžë§Œ ìž…ë ¥í•´ì£¼ì„¸ìš”.") ; a.value=""; a.focus() ; return true ; }
	if (a_len<2 || a_len>3) { alert(msg2); a.focus(); return true; }
	if (target=="í•¸ë“œí°") var limit = pcs.length;
	else var limit = tel.length;

	var cnt=0;
	for (var i=0; i<limit; i++) {
		if (target=="í•¸ë“œí°") { if (a.value==pcs[i]) cnt++; }
		else { if (a.value==tel[i]) cnt++; }
	}
	if (cnt==0) { alert("ìž˜ëª»ëœ ë²ˆí˜¸ìž…ë‹ˆë‹¤."); a.value=""; a.focus(); return true; }

	if (chkBlank_msg(b,msg1)) return true;
	if (b.value.search(isNum)) { alert("ìˆ«ìžë§Œ ìž…ë ¥í•´ì£¼ì„¸ìš”.") ; b.value=""; b.focus() ; return true ; }
	if (b_len<3 || b_len>4) { alert(msg2); b.focus(); return true; }

	if (chkBlank_msg(c,msg1)) return true;
	if (c.value.search(isNum)) { alert("ìˆ«ìžë§Œ ìž…ë ¥í•´ì£¼ì„¸ìš”.") ; c.value=""; c.focus() ; return true ; }
	if (c_len!=4) { alert(msg2); c.focus(); return true; }
	return false;
}


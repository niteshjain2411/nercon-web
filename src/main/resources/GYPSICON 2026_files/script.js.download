//----------------------- ì§ìž¥ëª… ìž…ë ¥ ----------------------------
function put_hosp(ha,hb)
{
	theForm = document.regist_frm;
	switch (ha)
	{
		case "of" :
			theForm.office.value = hb ;
			theForm.office_code.value = '' ;
			theForm.office_code.readOnly = false ;
			theForm.office_code_yn.value="";
		break;
	}
}
function OpenHosp2(z){
	var window_left = (screen.width-640)/2;
	var window_top = (screen.height-480)/2;
	murl = "/inc/hosp_search.html?field="+z
	window.open(murl,"HosWin",'width=658,height=250,scrollbars=yes,top=' + window_top + ',left=' + window_left + '');
}


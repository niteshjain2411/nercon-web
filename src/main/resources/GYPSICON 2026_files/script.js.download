// ëª¨ë“ ë¬¸ìž ëŒ€ë¬¸ìž ë³€í™˜
function Ucase(obj) {
	obj.value = obj.value.toUpperCase();
}

// ì²«ê¸€ìž ëŒ€ë¬¸ìž ë° ê³µë°±ì´í›„ ì²«ê¸€ìž ëŒ€ë¬¸ìžë³€í™˜
function Ucase_first_Up(obj) {
	var str_value = "";
	obj.value = obj.value.toLowerCase();
	sp_arry = obj.value.split(" ");
	sp_einx = sp_arry.length;
	for(var i=0; i<sp_einx; i++){
		sp_arry[i] = sp_arry[i].substring(0,1).toUpperCase() + sp_arry[i].substring(1);
		if((i+1) == sp_einx){ str_value += sp_arry[i]; }else{ str_value += sp_arry[i] + " "; }
	}
	obj.value = str_value;
}

// ì²«ê¸€ìž ëŒ€ë¬¸ìž ë° ê³µë°±ì´í›„ ì²«ê¸€ìž ëŒ€ë¬¸ìžë³€í™˜ ë° - ì´í›„ ì²«ê¸€ìž ëŒ€ë¬¸ìžë³€í™˜
function Ucase_first_Bk_Hp(obj) {
	var str_value = "";
	obj.value = obj.value.toLowerCase();
	sp_arry = obj.value.split(" ");
	sp_einx = sp_arry.length;
	for(var i=0; i<sp_einx; i++){
		sp_arry[i] = sp_arry[i].substring(0,1).toUpperCase() + sp_arry[i].substring(1);
		if((i+1) == sp_einx){ str_value += sp_arry[i]; }else{ str_value += sp_arry[i] + " "; }
	}

	var str_bkhp_value = "";
	Hyphen_arry = str_value.split("-");
	Hyphen_einx = Hyphen_arry.length;
	for(var i=0; i<Hyphen_einx; i++){
		Hyphen_arry[i] = Hyphen_arry[i].substring(0,1).toUpperCase() + Hyphen_arry[i].substring(1);
		if((i+1) == Hyphen_einx){ str_bkhp_value += Hyphen_arry[i]; }else{ str_bkhp_value += Hyphen_arry[i] + "-"; }
	}

	obj.value = str_bkhp_value;
}

// ì²«ê¸€ìž ëŒ€ë¬¸ìž ë° ê³µë°±ì´í›„ ì²«ê¸€ìž ëŒ€ë¬¸ìžë³€í™˜ (of, the ì œì™¸) 2014-01-10 Rain ì¶”ê°€
function Ucase_first_Bk_etc(obj) {
	var str_value = "";
	obj.value = obj.value.toLowerCase();
	sp_arry = obj.value.split(" ");
	sp_einx = sp_arry.length;
	for(var i=0; i<sp_einx; i++){
		sp_arry[i] = sp_arry[i].substring(0,1).toUpperCase() + sp_arry[i].substring(1);
		if((i+1) == sp_einx){ str_value += sp_arry[i]; }else{ str_value += sp_arry[i] + " "; }
	}
	
	var str_bkhp_value = str_value.replace(/ Of /gi, ' of '); // " Of " --> " of " ì¹˜í™˜
	var str_bkhp_value = str_bkhp_value.replace(/ The /gi, ' the '); // " The " --> " the " ì¹˜í™˜

	obj.value = str_bkhp_value;
}


function chkEvent(f) { //ê´€ë¦¬ìž ì¼ì • ê´€ë¦¬ 
	if (chkBlank_msg(f.event, "í–‰ì‚¬ëª…ì„ ìž…ë ¥í•˜ì„¸ìš”..")) return false;
	if (chkBlank_msg(f.event_start, "í–‰ì‚¬ì‹œìž‘ì¼ì„ ìž…ë ¥í•˜ì„¸ìš”")) return false;

	var msg = (f.mode.value=="edit") ? "ìˆ˜ì •" : "ë“±ë¡";
	msg += "í•˜ì‹œê² ìŠµë‹ˆê¹Œ?";

	if (!confirm(msg)) return false;
	return true;
}

function charTypeChk(ctype,msg,fval){ // ë¬¸ìží˜•ì‹ ì²´í¬
	var reg_text="";
	var reg_msg="";
	switch(ctype){
		case 'kor':// í•œê¸€ë§Œ
			reg_text=/^[ê°€-íž£]+$/;
			reg_msg="í•œê¸€ë§Œ ê°€ëŠ¥í•©ë‹ˆë‹¤.";
		break;
		case 'kor_s':// í•œê¸€ + ê³µë°±
			reg_text=/^[ê°€-íž£\s]+$/;
			reg_msg="í•œê¸€ê³¼ ê³µë°±ë§Œ ê°€ëŠ¥í•©ë‹ˆë‹¤.";
		break;
		case 'eng':// ì˜ë¬¸ë§Œ
			reg_text=/^[a-zA-Z]+$/;
			reg_msg="ì˜ë¬¸ë§Œ ê°€ëŠ¥í•©ë‹ˆë‹¤.";
		break;
		case 'eng_s':// ì˜ë¬¸ + ê³µë°± + í•˜ì´í”ˆ
			reg_text=/^[a-zA-Z\-\s]+$/;
			reg_msg="ì˜ë¬¸,ê³µë°±,í•˜ì´í”ˆ(`-`) ë§Œ ê°€ëŠ¥í•©ë‹ˆë‹¤.";
		break;
		case 'email':// ì˜ë¬¸ + ìˆ«ìž + ì–¸ë”ë°” + ë„íŠ¸
			reg_text=/^([\w-]+(?:\.[\w-]+)*)@((?:[\w-]+\.)*\w[\w-]{0,66})\.([a-z]{2,6}(?:\.[a-z]{2})?)$/;
			reg_msg="ì´ë©”ì¼ ì£¼ì†Œ í˜•ì‹ì´ ë§žì§€ ì•ŠìŠµë‹ˆë‹¤.";
		break;
		case 'tel':// ìˆ«ìž + ìžë¦¿ìˆ˜
			reg_text=/^[0-9]{2,3}-[0-9]{3,4}-[0-9]{4}$/;
			reg_msg="ì „í™”ë²ˆí˜¸ í˜•ì‹ì´ ë§žì§€ ì•ŠìŠµë‹ˆë‹¤.";
		break;
		case 'number': // ìˆ«ìžë§Œ
			reg_text=/^[0-9]+$/;
			reg_msg="ìˆ«ìžë§Œ ê°€ëŠ¥í•©ë‹ˆë‹¤.";
		break;
	}
	if(reg_text.test(fval) === false) {
		var alert_msg = (msg)?msg:reg_msg;
		alert(alert_msg);
		return true;
	}else{
	return false;
	}
}


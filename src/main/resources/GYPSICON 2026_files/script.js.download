// techNote íšŒì› ë¹„ë°€ë²ˆí˜¸ ìž…ë ¥
function LoginFrm(f) {
	if (chkBlank_msg(f.user_id,"ì•„ì´ë””ë¥¼ ìž…ë ¥í•´ ì£¼ì„¸ìš”")) return false;
	if (chkBlank_msg(f.kname,"ì´ë¦„ì„ ìž…ë ¥í•´ ì£¼ì„¸ìš”")) return false;
	if (chkBlank_msg(f.jumin,"ì£¼ë¯¼ë“±ë¡ë²ˆí˜¸ ì•žìžë¦¬ë¥¼ ìž…ë ¥í•´ ì£¼ì„¸ìš”")) return false;
	if (chkBlank_msg(f.pwd,"ì‹ ê·œë¹„ë°€ë²ˆí˜¸ë¥¼ ìž…ë ¥í•´ ì£¼ì„¸ìš”")) return false;
	if (f.pwd.value.length <6) {
		alert("ë¹„ë°€ë²ˆí˜¸ëŠ” ì˜ë¬¸ + ìˆ«ìž, 6~16ìž ë‚´ì™¸ë¡œ ìž…ë ¥í•´ ì£¼ì„¸ìš”.");
		f.pwd.focus();
		return false;
	}
	if (chkBlank_msg(f.re_pwd,"ë¹„ë°€ë²ˆí˜¸ í™•ì¸ì„ ìž…ë ¥í•´ ì£¼ì„¸ìš”")) return false;
	if (f.re_pwd.value!=f.pwd.value){
		alert("ì‹ ê·œë¹„ë°€ë²ˆí˜¸ì™€ ë¹„ë°€ë²ˆí˜¸ í™•ì¸ì´ ë™ì¼í•˜ì§€ ì•ŠìŠµë‹ˆë‹¤.");
		return false;
	}
	f.action="/pwd_change.php";
	return true;
}
// ë¹„ë°€ë²ˆí˜¸ ë³€ê²½
function PwdChagne(f) {
	if (chkBlank_msg(f.pwd,"í˜„ìž¬ë¹„ë°€ë²ˆí˜¸ë¥¼ ìž…ë ¥í•´ ì£¼ì„¸ìš”")) return false;
	if (chkBlank_msg(f.new_pwd,"ì‹ ê·œë¹„ë°€ë²ˆí˜¸ë¥¼ ìž…ë ¥í•´ ì£¼ì„¸ìš”")) return false;
	if (f.new_pwd.value.length <6) {
		alert("ë¹„ë°€ë²ˆí˜¸ëŠ” ì˜ë¬¸ + ìˆ«ìž, 6~16ìž ë‚´ì™¸ë¡œ ìž…ë ¥í•´ ì£¼ì„¸ìš”.");
		f.new_pwd.focus();
		return false;
	}
	if (chkBlank_msg(f.new_pwd_re,"ë¹„ë°€ë²ˆí˜¸ í™•ì¸ì„ ìž…ë ¥í•´ ì£¼ì„¸ìš”")) return false;
	if (f.new_pwd_re.value!=f.new_pwd.value){
		alert("ì‹ ê·œë¹„ë°€ë²ˆí˜¸ì™€ ë¹„ë°€ë²ˆí˜¸ í™•ì¸ì´ ë™ì¼í•˜ì§€ ì•ŠìŠµë‹ˆë‹¤.");
		return false;
	}
	f.action="pwd_change.php";
	if(!confirm("ë¹„ë°€ë²ˆí˜¸ë¥¼ ë³€ê²½í•˜ì‹œê² ìŠµë‹ˆê¹Œ?")) return false;
	return true;
}


var wWidth = 0;
$('#samplem').text('wWidth');
$(function(e){
	var $this = $(this),
		wWidth = $(window).innerWidth();
	
	$(document).ready(function(e){
		var loadCmnApp = (function(e){
			"user strict";
			
			function cmnFunc(){
				// event
				datepicker();
                ddayCounter();
                gnb();
                mainSubscribe();
				mainVisual();
                speakerSlide();
                videoSlide();
				// rollingSpeakers();
				// rollingBanner();
				
				$('.rolling-banner .slick-slide img').on('load',function(e){
					$('.rolling-banner .slick-arrow').css('height','');	
					var bannerH = $('.rolling-banner .slick-slide img').outerHeight();
					$('.rolling-banner .slick-arrow').css('height',bannerH);		
				});

				if(wWidth <= 1024){
					mGnb();
				}else{
					gnb();
					if($('#dim').hasClass('mobile')){
						$(this).stop().fadeOut(100);
					}
				}

				if(wWidth < 768){
					mQuickLayout();
				}else{
					quickLayout();
				}
			}
			
			function cmnResize(){
				// resize event
				wWidth = $(window).outerWidth();

				var bannerH = $('.rolling-banner .slick-slide img').outerHeight();
				$('.rolling-banner .slick-arrow').css('height',bannerH);	

				if(wWidth <= 1024){
					mGnb();
				}else{
					gnb();
					if($('#dim').hasClass('mobile')){
						$(this).stop().fadeOut(100);
					}
				}

				if(wWidth < 768){
					mQuickLayout();
				}else{
					quickLayout();
				}
			}
			
			function cmnScroll(){
				// scroll event
				btnTop();
			}
			
			return{
				cmnInit: function(e){
					cmnFunc();
				},
				cmnResize: function(e){
					$(window).resize(function(e){
						wWidth = $(window).outerWidth();
						//wWidth = windowWidth();	
						cmnResize();
					});
				},
				
				cmnScroll: function(e){
					$(window).scroll(function(e){
						if($(this).scrollTop() > 200){
							$('.btn-top').stop().fadeIn(100);
						}else{
							$('.btn-top').stop().fadeOut(100);
						}
						cmnScroll();
					});
				}
			}
		})();
		
		/* ====================
			* run
		===================== */
		 // init
		loadCmnApp.cmnInit();
		// resize
		loadCmnApp.cmnResize();
		// scroll
		loadCmnApp.cmnScroll();
	});
});

function windowWidth() {
    if($(document).innerHeight() > $(window).innerHeight()) {
        return $(window).innerWidth() - 17;
    } else {
        return $(window).innerWidth();
    }
}

function gnb(){
	$('#gnb > li > a').off('click');
	$('#gnb > li').mouseenter(function(e){
		$(this).children().next('ul').stop().slideDown(300);
		$('#gnb > li').not(this).children().next('ul').stop().slideUp(200);
	});
	$('#gnb').mouseleave(function(e){
		$('#gnb > li > ul').stop().slideUp(200);
	});
}

function ddayCounter(){
	// D-day ë‚ ì§œì™€ ì‹œê°„ ì„¤ì • (YYYY, MM(0ë¶€í„° 11), DD, HH, MM, SS)
    
    const dDayDate = new Date(2025, 9, 28, 0, 0, 0); // 2023ë…„ 8ì›” 15ì¼ 12ì‹œ 0ë¶„ 0ì´ˆ                    
    const p_start = new Date("2025-01-01");

    // D-dayê¹Œì§€ ë‚¨ì€ ì‹œê°„ì„ ê³„ì‚°í•˜ì—¬ í‘œì‹œí•˜ëŠ” í•¨ìˆ˜
    function updateDdayTimer() {
        //const dDayTimerDiv = document.getElementById('dDayTimer');
        const dDayTimerDay = document.getElementById('cday');

        const now = new Date();
        const timeDiff = Math.max(0, Math.floor((dDayDate - now) / 1000)); // ìŒìˆ˜ ê°’ ë°©ì§€

        const days = Math.floor(timeDiff / 86400);
        

        const p = Math.round(((now - p_start) / (dDayDate - p_start)) * 100) + "%";

        dDayTimerDay.textContent = `${days}`;
    

    }

    // íŽ˜ì´ì§€ ë¡œë“œ ì‹œ D-day íƒ€ì´ë¨¸ ì—…ë°ì´íŠ¸ í•¨ìˆ˜ í˜¸ì¶œ
    updateDdayTimer();

    // 1ì´ˆë§ˆë‹¤ D-day íƒ€ì´ë¨¸ ì—…ë°ì´íŠ¸ í•¨ìˆ˜ í˜¸ì¶œ
    setInterval(updateDdayTimer, 1000); // 1ì´ˆ = 1000ë°€ë¦¬ì´ˆ
}

function mGnb(){
	$('#gnb > li').off('mouseenter');
	$('#gnb').off('mouseleave');
	$('#gnb > li > a').off().on('click',function(e){
		if($(this).next('ul').length){
			$(this).next('ul').stop().slideToggle(300);
			$('#gnb > li > a').not(this).next('ul').stop().slideUp(200);
			return false;
		}		
	});
	$('#dim, .btn-slide-close').on('click',function(e){
		$('.gnb-wrap').stop().animate({'left':'-100%'},400);
		$('#dim').stop().fadeOut(100);
	});
	$('.btn-slide-open').on('click',function(e){
		$('.gnb-wrap').show().stop().animate({'left':'0'},400);
		$('#dim').stop().fadeIn(100);	
	});
}

function btnTop(){
	$('.btn-top').on('click',function(e){
		$('html, body').stop().animate({'scrollTop': 0},400);
		return false;
	});
}

